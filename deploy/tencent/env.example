# Copy only for syntax validation. Production values are generated on-server by
# scripts/generate-secrets.sh and are never committed.
COMPOSE_PROJECT_NAME=summerwork
SUMMERWORK_APP_ROOT=../..
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_64_HEX
SUMMERWORK_DB_VOLUME=summerwork_db_data
SUMMERWORK_DB_CONFIG_VOLUME=summerwork_db_config

JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_AT_LEAST_40_CHARS
JWT_EXPIRY=3600
ANON_KEY=CHANGE_ME_LEGACY_ANON_JWT
SERVICE_ROLE_KEY=CHANGE_ME_LEGACY_SERVICE_ROLE_JWT
JWT_KEYS=[]
JWT_JWKS={"keys":[]}
ANON_KEY_ASYMMETRIC=CHANGE_ME_ASYMMETRIC_ANON_JWT
SERVICE_ROLE_KEY_ASYMMETRIC=CHANGE_ME_ASYMMETRIC_SERVICE_ROLE_JWT
SUPABASE_PUBLISHABLE_KEY=sb_publishable_CHANGE_ME
SUPABASE_SECRET_KEY=sb_secret_CHANGE_ME
SECRET_KEY_BASE=CHANGE_ME_RANDOM_128_HEX
REALTIME_DB_ENC_KEY=CHANGE_ME_RANDOM_32_HEX

SITE_URL=https://summerwork.ilelezhan.cn
API_EXTERNAL_URL=https://summerwork-api.ilelezhan.cn/auth/v1
