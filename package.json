{
  "name": "summerwork-closed-loop",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && npm run test:unit && npm run test:render",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:render": "node --test tests/rendered-html.test.mjs",
    "test:db:local": "bash scripts/verify-local-postgres.sh",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "plan:import": "node scripts/import-summer-plan.mjs",
    "supabase:push": "node --env-file-if-exists=.env.local scripts/push-supabase.mjs",
    "supabase:sync-plan": "node --env-file-if-exists=.env.local scripts/sync-summer-plan.mjs",
    "supabase:verify": "node --env-file-if-exists=.env.local scripts/verify-supabase-permissions.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "next": "^16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.0",
    "@cloudflare/workers-types": "^5.20260716.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "supabase": "^2.109.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "4.111.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "type": "module"
}
